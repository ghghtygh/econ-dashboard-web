# ---- Application ----
VITE_API_BASE_URL=/api
VITE_APP_TITLE=Market Pulse Dashboard

# ---- Environment ----
# development | staging | production
VITE_APP_ENV=development

# ---- External Data API Keys (mock-api server) ----
# Without these keys, the server falls back to generated mock data.

# FRED (Federal Reserve Economic Data) – free at https://fred.stlouisfed.org/docs/api/api_key.html
# Provides: VIX, CPI, 10Y Treasury yield, Fed Funds Rate, Unemployment
FRED_API_KEY=

# Alpha Vantage – free tier at https://www.alphavantage.co/support/#api-key
# Provides: S&P 500 (SPY ETF), USD/KRW forex
ALPHA_VANTAGE_API_KEY=

# CoinGecko – no key required (free public API)
# Provides: Bitcoin, Ethereum prices and history
